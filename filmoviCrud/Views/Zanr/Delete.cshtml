@model Zanr

@{
    ViewData["Title"] = "Brisanje zanra";
}

<h1>Brisanje zanra</h1>

<h3>Da li ste sigurni da zelite da obrisete ovaj zanr?</h3>

<div>
    <dl class="row">
        <dt class="col-sm-2">
            ID
        </dt>
        <dd class="col-sm-10">
            @Model.Id
        </dd>

        <dt class="col-sm-2">
            Naziv
        </dt>
        <dd class="col-sm-10">
            @Model.Naziv
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />

        <button type="submit" class="btn btn-danger">
            Obrisi
        </button>

        <a asp-action="Index"
           class="btn btn-secondary">
            Otkazi
        </a>
    </form>
</div>
